<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Caribbean Streams</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Inter', 'sans-serif'] },
          colors: {
            brand: { black: '#050505', dark: '#0a0a0a', gray: '#171717', light: '#e5e5e5' }
          }
        }
      }
    }
  </script>
  <style>
    ::selection { background: white; color: black; }
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #0a0a0a; }
    ::-webkit-scrollbar-thumb { background: #262626; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #404040; }

    body { background: #050505; font-family: 'Inter', sans-serif; }

    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes shimmer {
      0% { left: -100%; }
      20% { left: 200%; }
      100% { left: 200%; }
    }

    @keyframes pulse-glow {
      0%, 100% { opacity: 0.4; }
      50% { opacity: 0.8; }
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    .animate-fade-in-up {
      animation: fadeInUp 0.8s ease-out forwards;
      opacity: 0;
    }

    .delay-100 { animation-delay: 0.1s; }
    .delay-200 { animation-delay: 0.2s; }
    .delay-300 { animation-delay: 0.3s; }
    .delay-400 { animation-delay: 0.4s; }
    .delay-500 { animation-delay: 0.5s; }

    .btn-shimmer {
      position: relative;
      overflow: hidden;
    }
    .btn-shimmer::after {
      content: '';
      position: absolute;
      top: 0; left: -100%;
      width: 60%; height: 100%;
      background: linear-gradient(to right, transparent, rgba(255,255,255,0.3), transparent);
      animation: shimmer 3s infinite cubic-bezier(0.4, 0, 0.2, 1);
    }

    .card-hover {
      transition: all 0.3s ease;
    }
    .card-hover:hover {
      transform: translateY(-4px);
      border-color: rgba(129, 140, 248, 0.3);
      box-shadow: 0 10px 40px rgba(129, 140, 248, 0.1);
    }
    .card-hover:hover .card-overlay {
      opacity: 1;
    }
    .card-hover:hover .play-icon {
      transform: scale(1);
      opacity: 1;
    }

    .modal-backdrop {
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }

    .grain {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      pointer-events: none;
      z-index: 9999;
      opacity: 0.03;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    }

    .scroll-reveal {
      visibility: hidden;
    }
    .scroll-reveal.visible {
      visibility: visible;
      animation: fadeInUp 0.8s ease-out forwards;
    }

    .input-field {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 6px;
      padding: 10px 14px;
      color: white;
      font-size: 0.875rem;
      width: 100%;
      transition: border-color 0.2s;
      outline: none;
    }
    .input-field:focus {
      border-color: rgba(129, 140, 248, 0.5);
    }
    .input-field::placeholder {
      color: #525252;
    }

    .hero-gradient {
      background: linear-gradient(135deg, #050505 0%, #0c0a1a 40%, #0a1628 70%, #050505 100%);
    }

    .glow-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      animation: pulse-glow 4s ease-in-out infinite;
    }
  </style>
</head>
<body class="text-white min-h-screen">

  <!-- Grain -->
  <div class="grain"></div>

  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 h-16 z-50 flex items-center justify-between px-6 bg-brand-black/80 backdrop-blur-xl border-b border-white/5">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-indigo-600 flex items-center justify-center">
        <iconify-icon icon="lucide:play" width="16" class="text-white"></iconify-icon>
      </div>
      <span class="text-base font-semibold tracking-tight">Caribbean Streams</span>
    </div>
    <div class="flex items-center gap-3">
      <button onclick="openLogin()" class="text-xs font-medium text-neutral-400 hover:text-white transition-colors duration-300 px-3 py-2">
        Login
      </button>
      <button onclick="openPayment()" class="btn-shimmer text-xs font-semibold bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-lg transition-colors duration-300">
        Subscribe
      </button>
      <button onclick="openAdminLogin()" class="text-xs font-medium text-neutral-500 hover:text-amber-400 transition-colors duration-300 px-2 py-2">
        <iconify-icon icon="lucide:shield" width="16"></iconify-icon>
      </button>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero-gradient relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
    <!-- Glow orbs -->
    <div class="glow-orb w-96 h-96 bg-indigo-600/20 top-20 -left-48" style="position:absolute;"></div>
    <div class="glow-orb w-80 h-80 bg-purple-600/15 bottom-20 -right-40" style="position:absolute; animation-delay:2s;"></div>

    <div class="relative z-10 text-center px-6 max-w-5xl mx-auto">
      <div class="animate-fade-in-up">
        <span class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-indigo-400 mb-6">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          Now Streaming
        </span>
      </div>

      <h1 class="animate-fade-in-up delay-100 text-5xl md:text-8xl lg:text-[120px] font-semibold leading-none tracking-tighter uppercase mb-6">
        Caribbean<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400">Streams</span>
      </h1>

      <p class="animate-fade-in-up delay-200 text-sm md:text-base font-light text-neutral-400 max-w-xl mx-auto mb-10 leading-relaxed">
        Stream the best of Caribbean cinema, TV shows, and exclusive originals. Unlimited entertainment, one subscription.
      </p>

      <div class="animate-fade-in-up delay-300 flex flex-col sm:flex-row gap-4 justify-center">
        <button onclick="openPayment()" class="btn-shimmer bg-white text-black text-sm font-semibold tracking-wide uppercase px-8 py-3.5 rounded-lg hover:bg-neutral-200 transition-colors duration-300">
          Start Watching
        </button>
        <button onclick="document.getElementById('content').scrollIntoView({behavior:'smooth'})" class="border border-white/10 text-white text-sm font-medium tracking-wide uppercase px-8 py-3.5 rounded-lg hover:border-white/30 transition-all duration-300">
          Browse Content
        </button>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-fade-in-up delay-500" style="animation: float 2s ease-in-out infinite;">
      <iconify-icon icon="lucide:arrow-down" width="20" class="text-neutral-600"></iconify-icon>
    </div>
  </section>

  <!-- Content Section -->
  <section id="content" class="px-6 py-24 md:py-32 max-w-7xl mx-auto">
    <div class="scroll-reveal flex items-end justify-between mb-12">
      <div>
        <span class="text-[10px] font-bold uppercase tracking-widest text-indigo-400 mb-3 block">Library</span>
        <h2 class="text-3xl md:text-4xl font-semibold tracking-tight">Trending Now</h2>
      </div>
      <span class="text-xs text-neutral-500 font-medium" id="movieCount">0 titles</span>
    </div>

    <!-- Empty State -->
    <div id="emptyState" class="scroll-reveal border border-dashed border-white/10 rounded-xl py-24 flex flex-col items-center justify-center text-center">
      <div class="w-16 h-16 rounded-full bg-white/5 flex items-center justify-center mb-6">
        <iconify-icon icon="lucide:film" width="28" class="text-neutral-600"></iconify-icon>
      </div>
      <p class="text-neutral-500 text-sm font-light mb-2">No content available yet</p>
      <p class="text-neutral-700 text-xs font-light">Admin can upload movies from the dashboard</p>
    </div>

    <!-- Movie Grid -->
    <div id="movieGrid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6"></div>
  </section>

  <!-- Features Section -->
  <section class="px-6 py-24 md:py-32 border-t border-white/5">
    <div class="max-w-7xl mx-auto">
      <div class="scroll-reveal text-center mb-16">
        <span class="text-[10px] font-bold uppercase tracking-widest text-indigo-400 mb-3 block">Why Us</span>
        <h2 class="text-3xl md:text-4xl font-semibold tracking-tight">Built for Caribbean Entertainment</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="scroll-reveal card-hover bg-neutral-900 border border-white/5 rounded-xl p-8">
          <div class="w-12 h-12 rounded-lg bg-indigo-600/10 flex items-center justify-center mb-6">
            <iconify-icon icon="lucide:tv" width="22" class="text-indigo-400"></iconify-icon>
          </div>
          <h3 class="text-base font-medium tracking-tight mb-3">Unlimited Streaming</h3>
          <p class="text-sm font-light text-neutral-400 leading-relaxed">Watch as much as you want, anytime, anywhere. No limits on your entertainment.</p>
        </div>

        <div class="scroll-reveal card-hover bg-neutral-900 border border-white/5 rounded-xl p-8">
          <div class="w-12 h-12 rounded-lg bg-green-600/10 flex items-center justify-center mb-6">
            <iconify-icon icon="lucide:zap" width="22" class="text-green-400"></iconify-icon>
          </div>
          <h3 class="text-base font-medium tracking-tight mb-3">Instant Access</h3>
          <p class="text-sm font-light text-neutral-400 leading-relaxed">Subscribe and start watching immediately. No waiting, no contracts, cancel anytime.</p>
        </div>

        <div class="scroll-reveal card-hover bg-neutral-900 border border-white/5 rounded-xl p-8">
          <div class="w-12 h-12 rounded-lg bg-purple-600/10 flex items-center justify-center mb-6">
            <iconify-icon icon="lucide:globe" width="22" class="text-purple-400"></iconify-icon>
          </div>
          <h3 class="text-base font-medium tracking-tight mb-3">Caribbean First</h3>
          <p class="text-sm font-light text-neutral-400 leading-relaxed">Curated collection of Caribbean films, shows, and exclusive originals you won't find elsewhere.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="px-6 py-24 md:py-32 border-t border-white/5">
    <div class="max-w-7xl mx-auto">
      <div class="scroll-reveal text-center mb-16">
        <span class="text-[10px] font-bold uppercase tracking-widest text-indigo-400 mb-3 block">Pricing</span>
        <h2 class="text-3xl md:text-4xl font-semibold tracking-tight">One Plan, Everything Included</h2>
      </div>

      <div class="scroll-reveal max-w-md mx-auto">
        <div class="bg-neutral-900 border border-indigo-600/30 rounded-xl p-8 relative overflow-hidden">
          <div class="absolute top-0 right-0 bg-indigo-600 text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-bl-lg">
            Popular
          </div>
          <div class="mb-6">
            <h3 class="text-lg font-medium tracking-tight mb-1">Premium</h3>
            <p class="text-xs text-neutral-500">Full access to everything</p>
          </div>
          <div class="mb-6">
            <span class="text-4xl font-semibold">$9.99</span>
            <span class="text-sm text-neutral-500 font-light">/month</span>
          </div>
          <ul class="space-y-3 mb-8">
            <li class="flex items-center gap-3 text-sm font-light text-neutral-300">
              <iconify-icon icon="lucide:check" width="16" class="text-green-400 flex-shrink-0"></iconify-icon>
              Unlimited movies & shows
            </li>
            <li class="flex items-center gap-3 text-sm font-light text-neutral-300">
              <iconify-icon icon="lucide:check" width="16" class="text-green-400 flex-shrink-0"></iconify-icon>
              HD & 4K streaming
            </li>
            <li class="flex items-center gap-3 text-sm font-light text-neutral-300">
              <iconify-icon icon="lucide:check" width="16" class="text-green-400 flex-shrink-0"></iconify-icon>
              Exclusive Caribbean originals
            </li>
            <li class="flex items-center gap-3 text-sm font-light text-neutral-300">
              <iconify-icon icon="lucide:check" width="16" class="text-green-400 flex-shrink-0"></iconify-icon>
              Cancel anytime
            </li>
          </ul>
          <button onclick="openPayment()" class="btn-shimmer w-full bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold tracking-wide uppercase py-3.5 rounded-lg transition-colors duration-300">
            Subscribe Now
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="px-6 py-12 border-t border-white/5">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <div class="w-6 h-6 rounded bg-indigo-600 flex items-center justify-center">
          <iconify-icon icon="lucide:play" width="12" class="text-white"></iconify-icon>
        </div>
        <span class="text-sm font-medium text-neutral-500">Caribbean Streams</span>
      </div>
      <p class="text-xs text-neutral-600 font-light">&copy; 2025 Caribbean Streams. All rights reserved.</p>
    </div>
  </footer>

  <!-- ==================== MODALS ==================== -->

  <!-- Login Modal -->
  <div id="loginModal" class="fixed inset-0 z-[60] hidden items-center justify-center modal-backdrop bg-black/70">
    <div class="bg-brand-dark border border-white/10 rounded-xl w-full max-w-sm mx-4 p-8 animate-fade-in-up" style="animation-duration:0.4s;">
      <div class="flex items-center justify-between mb-8">
        <h3 class="text-lg font-medium tracking-tight">Sign In</h3>
        <button onclick="closeLogin()" class="text-neutral-600 hover:text-white transition-colors">
          <iconify-icon icon="lucide:x" width="18"></iconify-icon>
        </button>
      </div>
      <div class="space-y-4">
        <div>
          <label class="text-[10px] font-semibold uppercase tracking-widest text-neutral-500 mb-2 block">Email</label>
          <input type="email" id="loginEmail" placeholder="you@example.com" class="input-field" />
        </div>
        <div>
          <label class="text-[10px] font-semibold uppercase tracking-widest text-neutral-500 mb-2 block">Password</label>
          <input type="password" id="loginPassword" placeholder="••••••••" class="input-field" />
        </div>
        <button onclick="login()" class="w-full bg-white text-black text-sm font-semibold tracking-wide uppercase py-3 rounded-lg hover:bg-neutral-200 transition-colors duration-300 mt-2">
          Sign In
        </button>
      </div>
      <p class="text-xs text-neutral-600 text-center mt-6">Demo mode — any input works</p>
    </div>
  </div>

  <!-- Payment Modal -->
  <div id="paymentModal" class="fixed inset-0 z-[60] hidden items-center justify-center modal-backdrop bg-black/70">
    <div class="bg-brand-dark border border-white/10 rounded-xl w-full max-w-sm mx-4 p-8 animate-fade-in-up" style="animation-duration:0.4s;">
      <div class="flex items-center justify-between mb-8">
        <h3 class="text-lg font-medium tracking-tight">Subscribe</h3>
        <button onclick="closePayment()" class="text-neutral-600 hover:text-white transition-colors">
          <iconify-icon icon="lucide:x" width="18"></iconify-icon>
        </button>
      </div>

      <div class="bg-white/5 border border-white/5 rounded-lg p-4 mb-6">
        <div class="flex justify-between items-center">
          <div>
            <p class="text-sm font-medium">Premium Plan</p>
            <p class="text-xs text-neutral-500 mt-0.5">Full access, cancel anytime</p>
          </div>
          <span class="text-lg font-semibold">$9.99<span class="text-xs text-neutral-500 font-light">/mo</span></span>
        </div>
      </div>

      <div class="space-y-4">
        <div>
          <label class="text-[10px] font-semibold uppercase tracking-widest text-neutral-500 mb-2 block">Card Number</label>
          <input type="text" id="cardNumber" placeholder="4242 4242 4242 4242" class="input-field" maxlength="19" />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="text-[10px] font-semibold uppercase tracking-widest text-neutral-500 mb-2 block">Expiry</label>
            <input type="text" placeholder="MM/YY" class="input-field" maxlength="5" />
          </div>
          <div>
            <label class="text-[10px] font-semibold uppercase tracking-widest text-neutral-500 mb-2 block">CVV</label>
            <input type="text" placeholder="123" class="input-field" maxlength="4" />
          </div>
        </div>
        <button onclick="pay()" class="btn-shimmer w-full bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold tracking-wide uppercase py-3 rounded-lg transition-colors duration-300 mt-2">
          Pay Now
        </button>
      </div>
      <p class="text-xs text-neutral-600 text-center mt-6">Demo mode — no real charges</p>
    </div>
  </div>

  <!-- Admin Login Modal -->
  <div id="adminLoginModal" class="fixed inset-0 z-[60] hidden items-center justify-center modal-backdrop bg-black/70">
    <div class="bg-brand-dark border border-white/10 rounded-xl w-full max-w-sm mx-4 p-8 animate-fade-in-up" style="animation-duration:0.4s;">
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-amber-500/10 flex items-center justify-center">
            <iconify-icon icon="lucide:shield" width="16" class="text-amber-400"></iconify-icon>
          </div>
          <h3 class="text-lg font-medium tracking-tight">Admin Access</h3>
        </div>
        <button onclick="closeAdminLogin()" class="text-neutral-600 hover:text-white transition-colors">
          <iconify-icon icon="lucide:x" width="18"></iconify-icon>
        </button>
      </div>
      <div class="space-y-4">
        <div>
          <label class="text-[10px] font-semibold uppercase tracking-widest text-neutral-500 mb-2 block">Password</label>
          <input type="password" id="adminPassword" placeholder="Enter admin password" class="input-field" />
        </div>
        <button onclick="adminLogin()" class="w-full bg-amber-500 hover:bg-amber-400 text-black text-sm font-semibold tracking-wide uppercase py-3 rounded-lg transition-colors duration-300 mt-2">
          Enter Dashboard
        </button>
      </div>
      <p class="text-xs text-neutral-600 text-center mt-6">Default: admin123</p>
    </div>
  </div>

  <!-- Admin Dashboard Modal -->
  <div id="adminModal" class="fixed inset-0 z-[60] hidden items-center justify-center modal-backdrop bg-black/70 overflow-y-auto py-8">
    <div class="bg-brand-dark border border-white/10 rounded-xl w-full max-w-lg mx-4 p-8 animate-fade-in-up" style="animation-duration:0.4s;">
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-amber-500/10 flex items-center justify-center">
            <iconify-icon icon="lucide:upload" width="16" class="text-amber-400"></iconify-icon>
          </div>
          <h3 class="text-lg font-medium tracking-tight">Upload Content</h3>
        </div>
        <button onclick="closeAdmin()" class="text-neutral-600 hover:text-white transition-colors">
          <iconify-icon icon="lucide:x" width="18"></iconify-icon>
        </button>
      </div>

      <!-- Upload Form -->
      <div class="space-y-4 mb-8">
        <div>
          <label class="text-[10px] font-semibold uppercase tracking-widest text-neutral-500 mb-2 block">Title</label>
          <input type="text" id="movieTitle" placeholder="Movie or show title" class="input-field" />
        </div>
        <div>
          <label class="text-[10px] font-semibold uppercase tracking-widest text-neutral-500 mb-2 block">Video URL</label>
          <input type="text" id="movieURL" placeholder="https://..." class="input-field" />
        </div>
        <div>
          <label class="text-[10px] font-semibold uppercase tracking-widest text-neutral-500 mb-2 block">Description</label>
          <textarea id="movieDesc" placeholder="Brief description..." rows="3" class="input-field resize-none"></textarea>
        </div>
        <div>
          <label class="text-[10px] font-semibold uppercase tracking-widest text-neutral-500 mb-2 block">Genre</label>
          <select id="movieGenre" class="input-field">
            <option value="Drama">Drama</option>
            <option value="Comedy">Comedy</option>
            <option value="Action">Action</option>
            <option value="Thriller">Thriller</option>
            <option value="Documentary">Documentary</option>
            <option value="Romance">Romance</option>
          </select>
        </div>
        <button onclick="uploadMovie()" class="btn-shimmer w-full bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold tracking-wide uppercase py-3 rounded-lg transition-colors duration-300">
          Upload Movie
        </button>
      </div>

      <!-- Separator -->
      <div class="border-t border-white/5 pt-8">
        <h4 class="text-sm font-medium tracking-tight mb-4 flex items-center gap-2">
          <iconify-icon icon="lucide:list" width="16" class="text-neutral-500"></iconify-icon>
          Uploaded Content
          <span id="adminCount" class="text-[10px] font-bold bg-white/10 px-2 py-0.5 rounded-full text-neutral-400">0</span>
        </h4>
        <div id="adminList" class="space-y-2 max-h-64 overflow-y-auto pr-1">
          <p class="text-xs text-neutral-600 font-light">No content uploaded yet</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Video Player Modal -->
  <div id="playerModal" class="fixed inset-0 z-[70] hidden items-center justify-center modal-backdrop bg-black/90">
    <div class="w-full max-w-4xl mx-4 animate-fade-in-up" style="animation-duration:0.4s;">
      <div class="flex items-center justify-between mb-4">
        <h3 id="playerTitle" class="text-lg font-medium tracking-tight">Now Playing</h3>
        <button onclick="closePlayer()" class="text-neutral-600 hover:text-white transition-colors">
          <iconify-icon icon="lucide:x" width="20"></iconify-icon>
        </button>
      </div>
      <div class="aspect-video bg-brand-dark border border-white/10 rounded-xl overflow-hidden flex items-center justify-center">
        <div id="playerContent" class="w-full h-full flex items-center justify-center">
          <p class="text-neutral-600 text-sm">Loading...</p>
        </div>
      </div>
      <p id="playerDesc" class="text-xs text-neutral-500 mt-4 font-light"></p>
    </div>
  </div>

  <!-- Toast Notification -->
  <div id="toast" class="fixed bottom-8 left-1/2 -translate-x-1/2 z-[80] bg-neutral-900 border border-white/10 rounded-lg px-5 py-3 flex items-center gap-3 shadow-2xl transition-all duration-500 opacity-0 translate-y-4 pointer-events-none">
    <iconify-icon id="toastIcon" icon="lucide:check-circle" width="18" class="text-green-400"></iconify-icon>
    <span id="toastMsg" class="text-sm font-light text-neutral-300"></span>
  </div>


  <script>
    // ===== STATE =====
    const ADMIN_PASS = 'admin123';
    let loggedIn = false;
    let subscribed = false;
    let movies = [];

    // Seed with demo movies
    const demoMovies = [
      { title: 'Island Heat', url: '', desc: 'A thrilling drama set in the heart of Kingston.', genre: 'Drama', seed: 'island-heat' },
      { title: 'Sunset Cove', url: '', desc: 'Romance blooms on a secluded beach.', genre: 'Romance', seed: 'sunset-cove' },
      { title: 'Rude Boy Rising', url: '', desc: 'The rise of a dancehall legend.', genre: 'Documentary', seed: 'rude-boy' },
      { title: 'Caribbean Heist', url: '', desc: 'An action-packed adventure across the islands.', genre: 'Action', seed: 'caribbean-heist' },
      { title: 'Calypso Nights', url: '', desc: 'Comedy and music collide at Carnival.', genre: 'Comedy', seed: 'calypso-nights' },
      { title: 'Deep Blue Caribbean', url: '', desc: 'Exploring the hidden depths of the Caribbean Sea.', genre: 'Documentary', seed: 'deep-blue' },
    ];
    movies = [...demoMovies];

    // ===== MODAL HELPERS =====
    function showModal(id) {
      const m = document.getElementById(id);
      m.classList.remove('hidden');
      m.classList.add('flex');
    }
    function hideModal(id) {
      const m = document.getElementById(id);
      m.classList.add('hidden');
      m.classList.remove('flex');
    }

    // ===== TOAST =====
    function showToast(msg, icon = 'lucide:check-circle', color = 'text-green-400') {
      const toast = document.getElementById('toast');
      document.getElementById('toastMsg').textContent = msg;
      const ic = document.getElementById('toastIcon');
      ic.setAttribute('icon', icon);
      ic.className = color;
      toast.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
      toast.classList.add('opacity-100', 'translate-y-0');
      setTimeout(() => {
        toast.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
        toast.classList.remove('opacity-100', 'translate-y-0');
      }, 3000);
    }

    // ===== MODAL CONTROLS =====
    function openLogin() { showModal('loginModal'); }
    function closeLogin() { hideModal('loginModal'); }

    function openPayment() { showModal('paymentModal'); }
    function closePayment() { hideModal('paymentModal'); }

    function openAdminLogin() { showModal('adminLoginModal'); }
    function closeAdminLogin() { hideModal('adminLoginModal'); }

    function openAdmin() { showModal('adminModal'); renderAdmin(); }
    function closeAdmin() { hideModal('adminModal'); }

    function closePlayer() { hideModal('playerModal'); }

    // ===== ACTIONS =====
    function login() {
      loggedIn = true;
      closeLogin();
      showToast('Signed in successfully');
    }

    function pay() {
      subscribed = true;
      closePayment();
      showToast('Subscription activated — enjoy unlimited streaming!');
    }

    function adminLogin() {
      const pass = document.getElementById('adminPassword').value;
      if (pass === ADMIN_PASS) {
        closeAdminLogin();
        document.getElementById('adminPassword').value = '';
        openAdmin();
      } else {
        showToast('Incorrect password', 'lucide:alert-circle', 'text-red-400');
      }
    }

    function uploadMovie() {
      const title = document.getElementById('movieTitle').value.trim();
      const url = document.getElementById('movieURL').value.trim();
      const desc = document.getElementById('movieDesc').value.trim();
      const genre = document.getElementById('movieGenre').value;

      if (!title) {
        showToast('Please enter a title', 'lucide:alert-circle', 'text-amber-400');
        return;
      }

      movies.push({
        title,
        url,
        desc: desc || 'No description provided.',
        genre,
        seed: title.toLowerCase().replace(/\s+/g, '-') + '-' + Date.now()
      });

      // Clear form
      document.getElementById('movieTitle').value = '';
      document.getElementById('movieURL').value = '';
      document.getElementById('movieDesc').value = '';

      render();
      renderAdmin();
      showToast(`"${title}" uploaded successfully`);
    }

    function deleteMovie(index) {
      const title = movies[index].title;
      movies.splice(index, 1);
      render();
      renderAdmin();
      showToast(`"${title}" removed`, 'lucide:trash-2', 'text-red-400');
    }

    function watch(index) {
      if (!subscribed) {
        openPayment();
        return;
      }

      const m = movies[index];
      document.getElementById('playerTitle').textContent = m.title;
      document.getElementById('playerDesc').textContent = m.desc;

      const pc = document.getElementById('playerContent');
      if (m.url) {
        pc.innerHTML = `<iframe src="${m.url}" class="w-full h-full" frameborder="0" allowfullscreen allow="autoplay; encrypted-media"></iframe>`;
      } else {
        pc.innerHTML = `
          <div class="flex flex-col items-center justify-center text-center p-8">
            <div class="w-20 h-20 rounded-full bg-indigo-600/10 flex items-center justify-center mb-6">
              <iconify-icon icon="lucide:play" width="32" class="text-indigo-400"></iconify-icon>
            </div>
            <p class="text-neutral-400 text-sm font-light mb-1">${m.title}</p>
            <p class="text-neutral-600 text-xs font-light">${m.genre} • No video URL provided</p>
          </div>
        `;
      }

      showModal('playerModal');
    }

    // ===== RENDER =====
    const genreColors = {
      Drama: 'text-blue-400 bg-blue-400/10',
      Comedy: 'text-yellow-400 bg-yellow-400/10',
      Action: 'text-red-400 bg-red-400/10',
      Thriller: 'text-purple-400 bg-purple-400/10',
      Documentary: 'text-green-400 bg-green-400/10',
      Romance: 'text-pink-400 bg-pink-400/10',
    };

    function render() {
      const grid = document.getElementById('movieGrid');
      const empty = document.getElementById('emptyState');
      const countEl = document.getElementById('movieCount');

      countEl.textContent = `${movies.length} title${movies.length !== 1 ? 's' : ''}`;

      if (movies.length === 0) {
        grid.innerHTML = '';
        empty.style.display = 'flex';
        return;
      }

      empty.style.display = 'none';
      grid.innerHTML = movies.map((m, i) => {
        const gc = genreColors[m.genre] || 'text-neutral-400 bg-neutral-400/10';
        return `
          <div class="card-hover group relative bg-neutral-900 border border-white/5 rounded-xl overflow-hidden cursor-pointer" onclick="watch(${i})">
            <div class="relative aspect-[2/3] overflow-hidden bg-neutral-800">
              <img
                src="https://picsum.photos/seed/${m.seed}/400/600.jpg"
                alt="${m.title}"
                class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500"
                loading="lazy"
              />
              <div class="card-overlay absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 transition-opacity duration-300 flex items-end p-4">
                <div class="play-icon absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center scale-75 opacity-0 transition-all duration-300">
                  <iconify-icon icon="lucide:play" width="20" class="text-white ml-0.5"></iconify-icon>
                </div>
              </div>
              <span class="absolute top-3 left-3 text-[10px] font-bold uppercase tracking-widest ${gc} px-2 py-1 rounded">${m.genre}</span>
            </div>
            <div class="p-4">
              <h3 class="text-sm font-medium tracking-tight truncate">${m.title}</h3>
              <p class="text-xs text-neutral-600 font-light mt-1 truncate">${m.desc}</p>
            </div>
          </div>
        `;
      }).join('');
    }

    function renderAdmin() {
      const list = document.getElementById('adminList');
      const countEl = document.getElementById('adminCount');
      countEl.textContent = movies.length;

      if (movies.length === 0) {
        list.innerHTML = '<p class="text-xs text-neutral-600 font-light">No content uploaded yet</p>';
        return;
      }

      list.innerHTML = movies.map((m, i) => `
        <div class="flex items-center justify-between bg-white/5 rounded-lg px-4 py-3 group">
          <div class="flex items-center gap-3 min-w-0">
            <span class="text-xs text-neutral-600 font-mono w-5 flex-shrink-0">${String(i + 1).padStart(2, '0')}</span>
            <div class="min-w-0">
              <p class="text-sm font-medium truncate">${m.title}</p>
              <p class="text-[10px] text-neutral-600 uppercase tracking-wider">${m.genre}${m.url ? ' • Has URL' : ' • No URL'}</p>
            </div>
          </div>
          <button onclick="deleteMovie(${i})" class="text-neutral-700 hover:text-red-400 transition-colors flex-shrink-0 ml-2">
            <iconify-icon icon="lucide:trash-2" width="14"></iconify-icon>
          </button>
        </div>
      `).join('');
    }

    // Close modals on backdrop click
    document.querySelectorAll('.modal-backdrop, [id$="Modal"]').forEach(modal => {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
        }
      });
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.querySelectorAll('[id$="Modal"]').forEach(m => {
          m.classList.add('hidden');
          m.classList.remove('flex');
        });
      }
    });

    // Scroll reveal observer
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));

    // Init
    render();
  </script>

</body>
</html>
